# Set compression
Compression yes

# Specify forwarding options
ForwardAgent yes
ForwardX11 no
ForwardX11Trusted yes

# Fix for OSX Sierra no longer saving ssh keys in keychain
AddKeysToAgent yes
UseKeychain yes

# Set up session keep alive settings
ServerAliveInterval 100
ServerAliveCountMax 2

# Stop annoying me about asking for new keys
StrictHostKeyChecking accept-new

Host github.com
    User git
    IdentityFile ~/.ssh/github_ed25519
    IdentitiesOnly yes

Host github-weka
    Hostname github.com
    User git
    IdentityFile ~/.ssh/weka-github
    IdentitiesOnly yes

Host homelab homelab-k3s
    Hostname homelab-k3s.skjerven.io
    User homelab-admin
    IdentityFile ~/.ssh/homelab_ed25519
    IdentitiesOnly yes

Host euler nas1
    Hostname euler.skjerven.io
    User nas-admin
    Port 2022
    IdentityFile ~/.ssh/euler_ed25519
    IdentitiesOnly yes

Host ada nas2
    Hostname ada.skjerven.io
    User nas-admin
    Port 2022
    IdentityFile ~/.ssh/ada_ed25519
    IdentitiesOnly yes

Host pihole
    Hostname pihole-host.skjerven.io
    User pihole
    IdentityFile ~/.ssh/pihole_ed25519
    IdentitiesOnly yes
